# Production (Netlify): NOT needed — netlify.toml proxies /api/* to the backend
# Update the proxy URL in netlify.toml after deploying the backend

# Alternative (without proxy): Set this in Netlify env vars for direct API calls
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com/api

# Development: NOT needed — Next.js rewrites proxy /api/* -> localhost:8000
